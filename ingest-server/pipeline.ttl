@prefix rdfc: <https://w3id.org/rdf-connect#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix tree: <https://w3id.org/tree#>.
@prefix ex: <http://example.org/>.
@prefix rdfl: <https://w3id.org/rdf-lens/ontology#>.

### Import runners and processors
<> owl:imports <./node_modules/@rdfc/js-runner/index.ttl>.

<> owl:imports <./node_modules/@rdfc/file-utils-processors-ts/processors.ttl>.
<> owl:imports <./node_modules/@rdfc/sds-processors-ts/configs/sdsify.ttl>.
<> owl:imports <./node_modules/@rdfc/sds-processors-ts/configs/bucketizer.ttl>.
<> owl:imports <./node_modules/@rdfc/sds-storage-writer-ts/processor.ttl>.
<> owl:imports <./node_modules/@rdfc/replication-processor-ts/processor.ttl>.
<> owl:imports <./node_modules/@rdfc/buffer-processor-ts/processor.ttl>.
<> owl:imports <./node_modules/@rdfc/log-processor-ts/processor.ttl>.

### Define the channels

# Channel for rdfc:GlobRead → rdfc:Envsub (metadata)
<metadata> a rdfc:Reader, rdfc:Writer.

# Channel for rdfc:Envsub → rdfc:Bucketize (metadata)
<metadata/substituted> a rdfc:Reader, rdfc:Writer.

# Channel for rdfc:Bucketize → rdfc:IngestSDS (metadata)
<metadata/bucketized> a rdfc:Reader, rdfc:Writer.

# Channel for rdfc:ReadReplication → rdfc:Log
<ldes-raw> a rdfc:Reader, rdfc:Writer.

# Channel for rdfc:Log → rdfc:Bucketize
<logged> a rdfc:Reader, rdfc:Writer.

# Channel for rdfc:Bucketize → rdfc:IngestSDS
<bucketized> a rdfc:Reader, rdfc:Writer.


### Define the pipeline
<> a rdfc:Pipeline;
   rdfc:consistsOf [
       rdfc:instantiates rdfc:NodeRunner;
       rdfc:processor <fetcher>, <logger>, <mappingReader>, <validator>, <reporter>, <ingester>;
   ].


### Define the processors

# File reader channel for metadata input on rdfc:IngestSDS
<metadataReader> a rdfc:GlobRead;
    rdfc:glob [
                a rdfl:EnvVariable;
                rdfl:envDefault <./metadata.ttl>;
                rdfl:envKey "METADATA_FILE"
            ];
    rdfc:output <metadata>;
    rdfc:closeOnEnd "true"^^xsd:boolean.

# Processor to substitute environment variables in the metadata
<substitutor> a rdfc:Envsub;
    rdfc:input <metadata>;
    rdfc:output <metadata/substituted>.

# Processor to read and stream out a replication of an on disk saved stream.
<reader> a rdfc:ReadReplication;
    rdfc:outgoing <ldes-raw>;
    rdfc:savePath [
                    a rdfl:EnvVariable;
                    rdfl:envDefault <./data/replication-data.txt>;
                    rdfl:envKey "REPLICATION_DATA"
                  ].

<logger> a rdfc:Log;
    rdfc:reader <ldes-raw>;
    rdfc:level "debug";
    rdfc:label "input";
    rdfc:writer <logged> .

# Processor to bucketize the data
<bucketizer> a rdfc:Bucketize;
    rdfc:channels [
          rdfc:dataInput <logged>;
          rdfc:dataOutput <bucketized>;
          rdfc:metadataInput <metadata/substituted>;
          rdfc:metadataOutput <metadata/bucketized>;
      ];
    rdfc:bucketizeStrategy ( [
                               a tree:PageFragmentation;
                               tree:pageSize [
                                                 a rdfl:EnvVariable;
                                                 rdfl:envDefault 1000;
                                                 rdfl:envKey "PAGE_SIZE"
                                             ];
                           ]);
    rdfc:outputStreamId ex:BenchmarkStream.

# Processor to persist the SDS stream into a MongoDB instance
<ingester> a rdfc:IngestSDS;
    rdfc:dataInput <bucketized>;
    rdfc:metadataInput <metadata/bucketized>;
    rdfc:database [
          rdfc:url [
                     a rdfl:EnvVariable;
                     rdfl:envDefault <mongodb://root:password@mongodb:27017/ldes?authSource=admin>;
                     rdfl:envKey "DATABASE_URL"
                 ];
          rdfc:metadata "METADATA";
          rdfc:data "DATA";
          rdfc:index "INDEX";
      ].
